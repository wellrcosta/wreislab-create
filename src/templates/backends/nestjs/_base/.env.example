# ─── Dev workflow ───────────────────────────────────────────────────────────
# Local dev (app na máquina, infra no Docker):
#   pnpm dev:infra     → sobe banco/cache/queue no Docker
#   pnpm start:dev     → inicia o backend (1ª vez: aguarde ~60s o banco inicializar)
#
# Full stack Docker:   docker compose up --build
# ────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

APP_NAME={{PROJECT_NAME}}
APP_VERSION=0.1.0

LOG_LEVEL=info

CORS_ORIGIN=http://localhost:5173

SWAGGER_ENABLED=true
METRICS_ENABLED=true
