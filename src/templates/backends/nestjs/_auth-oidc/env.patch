
# OIDC configuration
# Verify the exact issuer value at: https://auth.DOMAIN.com/.well-known/openid-configuration
OIDC_ISSUER_URL=https://auth.DOMAIN.com

# Audience must match the 'aud' claim in the JWT.
# After first login, decode the token at jwt.io and verify the exact 'aud' value.
OIDC_AUDIENCE={{PROJECT_NAME}}

# JWKS endpoint. If empty, auto-discovered from OIDC_ISSUER_URL/.well-known/openid-configuration
OIDC_JWKS_URI=https://auth.DOMAIN.com/.well-known/jwks.json

# The JWT claim that contains the user's groups array
JWT_GROUPS_CLAIM=groups
