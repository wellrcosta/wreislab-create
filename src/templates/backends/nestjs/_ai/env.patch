
# ─── AI Integration ────────────────────────────────────────────────────────────
# Active provider: nvidia | openai | anthropic | gemini | deepseek | kimi | groq | custom
AI_PROVIDER=nvidia

# Default model override (leave empty to use each provider's built-in default)
AI_MODEL=

# NVIDIA NIM (free tier — https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxx

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Google Gemini
GEMINI_API_KEY=xxxxxxxxxxxx

# DeepSeek
DEEPSEEK_API_KEY=xxxxxxxxxxxx

# Kimi (Moonshot AI)
KIMI_API_KEY=xxxxxxxxxxxx

# Groq
GROQ_API_KEY=xxxxxxxxxxxx

# Custom OpenAI-compatible endpoint (provider=custom)
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=xxxxxxxxxxxx
